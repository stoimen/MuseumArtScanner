# Expo only inlines variables prefixed with EXPO_PUBLIC_ into the app bundle.
# All keys below must use that prefix or they will be undefined at runtime.

# AI Provider: "claude", "openai", or "gemini"
EXPO_PUBLIC_AI_PROVIDER=claude

# Anthropic API key (required if AI_PROVIDER=claude)
# Get one at https://console.anthropic.com/
EXPO_PUBLIC_ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key (required if AI_PROVIDER=openai)
EXPO_PUBLIC_OPENAI_API_KEY=sk-...

# Gemini API key (required if AI_PROVIDER=gemini)
EXPO_PUBLIC_GEMINI_API_KEY=AIza...
